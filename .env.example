# Core keys (see server/.env.example for the full list incl. optional
# auth/billing/Stripe/pricing variables).
DEEPGRAM_API_KEY=your_deepgram_key_here
GROQ_API_KEY=gsk_your_groq_key_here
PORT=3001

# Auth/billing is optional — fill DATABASE_URL + GOOGLE_CLIENT_ID + JWT_SECRET
# (and Stripe + pricing) in server/.env to enable accounts and credits.
DATABASE_URL=
GOOGLE_CLIENT_ID=
JWT_SECRET=
