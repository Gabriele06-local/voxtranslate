---
// Shared chrome for the legal pages (Terms, Privacy, Acceptable Use).
// NOTE: the content of these pages is a good-faith DRAFT template, not legal
// advice — it must be reviewed by a qualified lawyer before production use.
import Base from './Base.astro';

interface Props {
  title: string;
  updated?: string;
  version?: string;
}
const { title, updated = '10 June 2026', version = '2026-06-10' } = Astro.props;
---

<Base title={`${title} · VoxTranslate`}>
  <main class="legal">
    <a class="legal-back" href="/">← VoxTranslate</a>

    <div class="legal-draft" role="note">
      ⚠️ <strong>Draft template — not legal advice.</strong> This document is a
      starting point and must be reviewed and adapted by a qualified lawyer before
      you rely on it. It may not reflect the laws of your or your users' jurisdictions.
    </div>

    <header class="legal-header">
      <h1>{title}</h1>
      <p class="legal-meta">Last updated: {updated} · Version {version}</p>
    </header>

    <article class="legal-body">
      <slot />
    </article>

    <footer class="legal-footer-links">
      <a href="/terms">Terms</a> ·
      <a href="/privacy">Privacy</a> ·
      <a href="/acceptable-use">Acceptable Use</a>
    </footer>
  </main>

  <style is:global>
    .legal {
      max-width: 760px;
      margin: 0 auto;
      padding: 32px 20px 64px;
    }
    .legal-back {
      display: inline-block;
      margin-bottom: 20px;
      color: var(--muted);
      text-decoration: none;
      font-size: 0.9rem;
    }
    .legal-back:hover { color: var(--text); }
    .legal-draft {
      border: 1px solid var(--warning);
      background: rgba(245, 158, 11, 0.08);
      color: var(--text);
      border-radius: var(--radius);
      padding: 12px 16px;
      font-size: 0.88rem;
      margin-bottom: 28px;
    }
    .legal-header h1 { font-size: 1.7rem; margin: 0 0 6px; }
    .legal-meta { color: var(--muted); font-size: 0.85rem; margin: 0 0 8px; }
    .legal-body { color: var(--text); }
    .legal-body h2 { font-size: 1.15rem; margin: 32px 0 10px; }
    .legal-body h3 { font-size: 1rem; margin: 22px 0 8px; }
    .legal-body p, .legal-body li { color: var(--text); font-size: 0.95rem; }
    .legal-body a { color: var(--accent); }
    .legal-body ul { padding-left: 22px; }
    .legal-body li { margin: 6px 0; }
    .legal-body table {
      width: 100%;
      border-collapse: collapse;
      margin: 14px 0;
      font-size: 0.9rem;
    }
    .legal-body th, .legal-body td {
      border: 1px solid var(--border);
      padding: 8px 10px;
      text-align: left;
      vertical-align: top;
    }
    .legal-body th { background: var(--surface); color: var(--muted); font-weight: 600; }
    .legal-footer-links {
      margin-top: 48px;
      padding-top: 18px;
      border-top: 1px solid var(--border);
      text-align: center;
      color: var(--muted);
      font-size: 0.85rem;
    }
    .legal-footer-links a { color: var(--muted); text-decoration: underline; margin: 0 4px; }
    .legal-footer-links a:hover { color: var(--text); }
  </style>
</Base>
