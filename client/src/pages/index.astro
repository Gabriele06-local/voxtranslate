---
import Base from '../layouts/Base.astro';

// Languages supported by the translator (and therefore by the UI). Shown as
// endonyms so anyone can find their own language regardless of UI language.
const LANGS = [
  { code: 'it', name: 'Italiano' },
  { code: 'en', name: 'English' },
  { code: 'es', name: 'Español' },
  { code: 'fr', name: 'Français' },
  { code: 'de', name: 'Deutsch' },
  { code: 'pt', name: 'Português' },
  { code: 'ja', name: '日本語' },
  { code: 'zh', name: '中文' },
];
---

<Base title="VoxTranslate">
  <main class="app">
    <!-- ===================== HOME / LOBBY ===================== -->
    <section id="home" class="screen">
      <header class="home-header">
        <h1 class="brand">Vox<span>Translate</span></h1>
        <p class="tagline" data-i18n="tagline"></p>
      </header>

      <div class="home-body">
        <!-- You -->
        <div class="card">
          <div class="field-row">
            <label class="field grow">
              <span class="field-label" data-i18n="nameLabel"></span>
              <input id="name" type="text" maxlength="24" autocomplete="off" data-i18n-ph="namePlaceholder" />
            </label>
            <label class="field grow">
              <span class="field-label" data-i18n="langLabel"></span>
              <select id="lang">
                {LANGS.map((l) => <option value={l.code}>{l.name}</option>)}
              </select>
            </label>
          </div>
        </div>

        <!-- Create or join -->
        <div class="card">
          <span class="card-title" data-i18n="createOrJoin"></span>
          <label class="field">
            <span class="field-label" data-i18n="roomCode"></span>
            <div class="room-row">
              <input id="room" type="text" autocomplete="off" spellcheck="false" />
              <button id="dice" class="btn-ghost icon-btn" title="Random" aria-label="Random code">🎲</button>
            </div>
          </label>

          <div class="field">
            <span class="field-label" data-i18n="visibility"></span>
            <div class="seg" id="vis-group" role="group">
              <button type="button" class="seg-btn active" data-vis="public" data-i18n="public"></button>
              <button type="button" class="seg-btn" data-vis="private" data-i18n="private"></button>
            </div>
            <span class="hint" id="vis-hint"></span>
          </div>

          <button id="enter" class="btn-primary" data-i18n="connect"></button>
          <p id="home-status" class="status-line"></p>
        </div>

        <!-- Public rooms lobby -->
        <div class="card">
          <div class="card-title-row">
            <span class="card-title" data-i18n="publicRooms"></span>
            <button id="refresh" class="btn-ghost" data-i18n="refresh"></button>
          </div>
          <div id="rooms-list" class="rooms-list"></div>
        </div>
      </div>
    </section>

    <!-- ===================== SESSION ===================== -->
    <section id="session" class="screen hidden">
      <header class="session-header">
        <div class="header-left">
          <span class="conn-dot" id="conn-dot"></span>
          <button id="room-badge" class="room-badge" title="Copy room code"></button>
          <span class="vis-badge" id="vis-badge"></span>
          <span class="lang-pair" id="my-lang"></span>
        </div>
        <button id="disconnect" class="btn-ghost danger" data-i18n="disconnect"></button>
      </header>

      <div class="panel">
        <button id="mic" class="mic" aria-label="Record">
          <span class="mic-icon">🎙️</span>
          <span class="pulse-ring"></span>
        </button>
        <p id="mic-hint" class="mic-hint"></p>
        <label class="mode-toggle">
          <input type="checkbox" id="ptt-mode" />
          <span data-i18n="pttMode"></span>
        </label>
      </div>

      <div class="controls">
        <label class="mode-toggle">
          <input type="checkbox" id="auto-tts" checked />
          <span data-i18n="autoTts"></span>
        </label>
        <label class="field voice-field">
          <span class="field-label" data-i18n="voiceLabel"></span>
          <select id="voice-select"></select>
        </label>
      </div>

      <div id="log" class="log" aria-live="polite"></div>
    </section>
  </main>

  <style>
    .app {
      min-height: 100dvh;
      display: flex;
      flex-direction: column;
    }
    .screen {
      flex: 1;
      display: flex;
      flex-direction: column;
      min-height: 0;
    }
    .hidden {
      display: none !important;
    }

    /* ---------- Shared form bits ---------- */
    .card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 18px;
    }
    .card-title {
      display: block;
      font-size: 0.8rem;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: var(--muted);
      font-weight: 600;
      margin-bottom: 14px;
    }
    .card-title-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 12px;
    }
    .card-title-row .card-title {
      margin-bottom: 0;
    }
    .field {
      display: block;
      margin-bottom: 16px;
    }
    .field:last-child {
      margin-bottom: 0;
    }
    .field-row {
      display: flex;
      gap: 12px;
      flex-wrap: wrap;
    }
    .field-row .grow {
      flex: 1 1 140px;
      margin-bottom: 0;
    }
    .field-label {
      display: block;
      font-size: 0.76rem;
      text-transform: uppercase;
      letter-spacing: 0.04em;
      color: var(--muted);
      margin-bottom: 6px;
    }
    .hint {
      display: block;
      margin-top: 7px;
      font-size: 0.78rem;
      color: var(--muted);
      min-height: 1em;
    }
    input,
    select {
      width: 100%;
      background: var(--bg);
      border: 1px solid var(--border);
      color: var(--text);
      border-radius: 10px;
      padding: 12px;
      font-size: 16px; /* >=16px prevents iOS zoom-on-focus */
      outline: none;
      transition: border-color 0.15s;
    }
    input:focus,
    select:focus {
      border-color: var(--accent);
    }
    .room-row {
      display: flex;
      gap: 8px;
    }
    .room-row input {
      font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }
    .icon-btn {
      flex: none;
      font-size: 1.1rem;
      padding: 0 14px;
    }
    .btn-primary {
      width: 100%;
      min-height: 48px;
      background: var(--accent);
      color: #fff;
      border: none;
      border-radius: 10px;
      padding: 13px;
      font-size: 1rem;
      font-weight: 600;
      transition: filter 0.15s;
    }
    .btn-primary:hover {
      filter: brightness(1.08);
    }
    .btn-primary:active {
      transform: translateY(1px);
    }
    .btn-primary:disabled {
      opacity: 0.6;
    }
    .btn-ghost {
      background: transparent;
      border: 1px solid var(--border);
      color: var(--muted);
      border-radius: 8px;
      padding: 9px 12px;
      font-size: 0.85rem;
      transition: all 0.15s;
      white-space: nowrap;
    }
    .btn-ghost:hover {
      color: var(--text);
      border-color: var(--muted);
    }
    .btn-ghost.danger:hover {
      color: var(--rec);
      border-color: var(--rec);
    }
    .status-line {
      margin: 12px 0 0;
      min-height: 1.1em;
      font-size: 0.85rem;
      color: var(--muted);
    }
    .status-line.error {
      color: var(--rec);
    }

    /* Segmented control (visibility) */
    .seg {
      display: flex;
      gap: 8px;
    }
    .seg-btn {
      flex: 1;
      min-height: 44px;
      background: var(--bg);
      border: 1px solid var(--border);
      color: var(--muted);
      border-radius: 10px;
      padding: 10px;
      font-size: 0.95rem;
      transition: all 0.15s;
    }
    .seg-btn.active {
      border-color: var(--accent);
      color: var(--text);
      background: var(--accent-dim);
    }

    /* ---------- Home ---------- */
    .home-header {
      text-align: center;
      padding: 28px 18px 8px;
    }
    .brand {
      margin: 0;
      font-size: 1.9rem;
      font-weight: 700;
      letter-spacing: -0.02em;
    }
    .brand span {
      color: var(--accent);
    }
    .tagline {
      margin: 4px 0 0;
      color: var(--muted);
      font-size: 0.92rem;
    }
    .home-body {
      width: 100%;
      max-width: 480px;
      margin: 0 auto;
      padding: 14px 16px 28px;
      display: flex;
      flex-direction: column;
      gap: 14px;
    }

    /* Lobby list */
    .rooms-list {
      display: flex;
      flex-direction: column;
      gap: 10px;
    }
    .room-item {
      width: 100%;
      text-align: left;
      background: var(--bg);
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 12px 14px;
      transition: all 0.15s;
    }
    .room-item:hover {
      border-color: var(--accent);
    }
    .room-item:active {
      transform: translateY(1px);
    }
    .room-item-main {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 10px;
    }
    .room-item-code {
      font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
      font-weight: 600;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      color: var(--text);
    }
    .room-item-count {
      font-size: 0.82rem;
      color: var(--muted);
      flex: none;
    }
    .room-item-members {
      display: flex;
      flex-wrap: wrap;
      gap: 6px;
      margin-top: 8px;
    }
    .chip {
      font-size: 0.78rem;
      color: var(--text);
      background: var(--surface-2);
      border: 1px solid var(--border);
      border-radius: 999px;
      padding: 3px 9px;
    }
    .lobby-empty {
      color: var(--muted);
      text-align: center;
      font-size: 0.88rem;
      padding: 14px 0;
    }

    /* ---------- Session ---------- */
    .session-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 12px 16px;
      border-bottom: 1px solid var(--border);
      gap: 10px;
      position: sticky;
      top: 0;
      background: var(--bg);
      z-index: 5;
    }
    .header-left {
      display: flex;
      align-items: center;
      gap: 8px;
      min-width: 0;
      flex-wrap: wrap;
    }
    .conn-dot {
      width: 9px;
      height: 9px;
      border-radius: 50%;
      background: var(--muted);
      flex: none;
      transition: background 0.2s;
    }
    .conn-dot.connected {
      background: var(--success);
      box-shadow: 0 0 8px var(--success);
    }
    .room-badge {
      font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
      font-weight: 600;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      background: transparent;
      border: none;
      color: var(--text);
      padding: 0;
      cursor: pointer;
    }
    .vis-badge {
      font-size: 0.68rem;
      text-transform: uppercase;
      letter-spacing: 0.04em;
      color: var(--muted);
      border: 1px solid var(--border);
      border-radius: 999px;
      padding: 2px 8px;
    }
    .lang-pair {
      color: var(--muted);
      font-size: 0.85rem;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }
    .panel {
      display: flex;
      flex-direction: column;
      align-items: center;
      padding: 22px 18px 4px;
    }
    .controls {
      display: flex;
      flex-wrap: wrap;
      gap: 12px 22px;
      align-items: center;
      justify-content: center;
      padding: 6px 16px 12px;
      border-bottom: 1px solid var(--border);
    }
    .controls .voice-field {
      margin: 0;
      min-width: 200px;
      flex: 1 1 200px;
      max-width: 320px;
    }
    .controls .field-label {
      margin-bottom: 4px;
    }

    /* Mic button */
    .mic {
      position: relative;
      width: 140px;
      height: 140px;
      border-radius: 50%;
      background: var(--surface);
      border: 2px solid var(--border);
      color: var(--text);
      display: grid;
      place-items: center;
      transition: all 0.18s;
      touch-action: none;
      user-select: none;
      -webkit-user-select: none;
    }
    .mic:hover {
      border-color: var(--accent);
    }
    .mic-icon {
      font-size: 3rem;
      line-height: 1;
      pointer-events: none;
    }
    .mic.recording {
      border-color: var(--rec);
      background: rgba(239, 68, 68, 0.12);
    }
    .pulse-ring {
      position: absolute;
      inset: -2px;
      border-radius: 50%;
      border: 2px solid var(--rec);
      opacity: 0;
      pointer-events: none;
    }
    .mic.recording .pulse-ring {
      animation: pulse 1.4s ease-out infinite;
    }
    @keyframes pulse {
      0% {
        transform: scale(1);
        opacity: 0.7;
      }
      100% {
        transform: scale(1.5);
        opacity: 0;
      }
    }
    .mic-hint {
      color: var(--muted);
      font-size: 0.9rem;
      margin: 16px 0 10px;
      text-align: center;
    }
    .mode-toggle {
      display: flex;
      align-items: center;
      gap: 8px;
      color: var(--muted);
      font-size: 0.88rem;
      cursor: pointer;
    }
    .mode-toggle input {
      width: auto;
    }

    /* Message log */
    .log {
      flex: 1;
      overflow-y: auto;
      -webkit-overflow-scrolling: touch;
      padding: 16px;
      display: flex;
      flex-direction: column;
      gap: 10px;
      max-width: 760px;
      width: 100%;
      margin: 0 auto;
    }
    .log :global(.msg) {
      padding: 8px 12px;
      border-radius: 10px;
      background: var(--surface);
      border: 1px solid var(--border);
      word-wrap: break-word;
      max-width: 88%;
    }
    .log :global(.msg-from) {
      font-size: 0.72rem;
      text-transform: uppercase;
      letter-spacing: 0.04em;
      color: var(--muted);
      margin-bottom: 3px;
    }
    .log :global(.msg-own) {
      align-self: flex-end;
      background: var(--surface-2);
      border-color: var(--accent-dim);
    }
    .log :global(.msg-incoming) {
      align-self: flex-start;
    }
    .log :global(.msg-translated) {
      align-self: flex-start;
      color: var(--accent);
      font-weight: 600;
      font-size: 1.05rem;
      border-color: var(--accent-dim);
    }
    .log :global(.msg-interim) {
      align-self: flex-end;
      color: var(--muted);
      font-style: italic;
      background: transparent;
      border-style: dashed;
    }
    .log :global(.msg-error) {
      align-self: center;
      color: var(--rec);
      border-color: var(--rec);
      font-size: 0.88rem;
    }
    .log :global(.log-empty) {
      align-self: center;
      color: var(--muted);
      text-align: center;
      margin-top: 40px;
      font-size: 0.9rem;
    }

    @media (max-width: 420px) {
      .controls .voice-field {
        max-width: none;
      }
    }
  </style>

  <script>
