        nameLabel: 'あなたの名前（任意）', namePlaceholder: 'ゲスト',
        langLabel: 'あなたの言語', connect: '参加', enterRoom: 'ルームコードを入力してください',
        micDenied: 'マイクへのアクセスが拒否されました', recNotSupported: 'このブラウザは録音に対応していません',
        connecting: '接続中…', disconnect: '退出', autoTts: '翻訳を自動で読み上げる',
        voiceLabel: '音声', voiceAuto: '自動（言語に合わせる）', waiting: '音声を待っています…',
        tapStart: 'タップして話す', tapStop: '聞いています… タップして停止',
        holdTalk: '押している間だけ話す', releaseStop: '離して停止', pttMode: 'プッシュ・トゥ・トーク（長押し）',
        you: 'あなた', connectionLost: '接続が切れました — 再接続中…',
        createOrJoin: 'ルームを作成または参加', visibility: '公開設定', public: '公開', private: '非公開',
        publicRooms: '公開ルーム（オンライン）', noPublicRooms: '公開ルームはまだありません — 作成しましょう！',
        refresh: '更新', privateHint: '非公開ルームはロビーに表示されません',
      },
      zh: {
        tagline: '实时语音翻译', roomCode: '房间代码', copy: '复制',
        copied: '代码已复制', copyFailed: '复制失败 — 请手动选择',
        nameLabel: '你的名字（可选）', namePlaceholder: '访客',
        langLabel: '你的语言', connect: '加入', enterRoom: '请输入房间代码',
        micDenied: '麦克风访问被拒绝', recNotSupported: '此浏览器不支持录音',
        connecting: '连接中…', disconnect: '离开', autoTts: '自动朗读翻译',
        voiceLabel: '语音', voiceAuto: '自动（匹配语言）', waiting: '等待语音…',
        tapStart: '点按开始说话', tapStop: '正在聆听… 点按停止',
        holdTalk: '按住说话', releaseStop: '松开停止', pttMode: '按住说话',
        you: '你', connectionLost: '连接断开 — 正在重连…',
        createOrJoin: '创建或加入房间', visibility: '可见性', public: '公开', private: '私密',
        publicRooms: '在线公开房间', noPublicRooms: '还没有公开房间 — 创建一个吧！',
        refresh: '刷新', privateHint: '私密房间不会显示在大厅中',
      },
    };

    function detectLang() {
      const nav = (navigator.language || 'en').slice(0, 2).toLowerCase();
      return SUPPORTED.includes(nav) ? nav : 'en';
    }
    let uiLang = detectLang();
    const t = (key) => (I18N[uiLang] && I18N[uiLang][key]) || I18N.en[key] || key;

    function applyI18n() {
      document.documentElement.lang = uiLang;
      document.querySelectorAll('[data-i18n]').forEach((el) => {
        el.textContent = t(el.getAttribute('data-i18n'));
      });
      document.querySelectorAll('[data-i18n-ph]').forEach((el) => {
        el.setAttribute('placeholder', t(el.getAttribute('data-i18n-ph')));
      });
      updateVisHint();
    }

    // ====================================================================
    // Config + DOM
    // ====================================================================
    const WS_HOST = import.meta.env.PUBLIC_WS_HOST || location.host;
    const WS_PROTO = location.protocol === 'https:' ? 'wss:' : 'ws:';
    const WS_BASE = `${WS_PROTO}//${WS_HOST}`;
    const HTTP_BASE = WS_BASE.replace(/^ws/, 'http');

    const $ = (id) => document.getElementById(id);
    const homeScreen = $('home');
    const sessionScreen = $('session');
    const roomInput = $('room');
    const nameInput = $('name');
    const langSel = $('lang');
    const enterBtn = $('enter');
    const homeStatus = $('home-status');
    const visGroup = $('vis-group');
    const visHint = $('vis-hint');
    const roomsList = $('rooms-list');
    const micBtn = $('mic');
    const micHint = $('mic-hint');
    const pttMode = $('ptt-mode');
    const autoTtsEl = $('auto-tts');
    const voiceSelect = $('voice-select');
    const logEl = $('log');
    const connDot = $('conn-dot');
    const roomBadge = $('room-badge');
    const visBadge = $('vis-badge');
    const myLangEl = $('my-lang');

    // ====================================================================
    // State
    // ====================================================================
    const myId =
      (crypto && crypto.randomUUID && crypto.randomUUID()) ||
      `id-${Math.random().toString(36).slice(2)}-${Date.now()}`;
    let ws = null;
    let stream = null;
    let recorder = null;
    let isRecording = false;
    let interimEl = null;
    let manualClose = false;
    let reconnectTimer = null;
    let lobbyTimer = null;
    let visibilityPublic = true; // segmented control state
    let session = null; // { room, lang, name, isPublic }

    // ====================================================================
    // Home screen
    // ====================================================================
    function randomRoom() {
      const chars = 'abcdefghjkmnpqrstuvwxyz23456789';
      let s = '';
      for (let i = 0; i < 6; i++) s += chars[Math.floor(Math.random() * chars.length)];
      return s;
    }
    roomInput.value = randomRoom();
    $('dice').addEventListener('click', () => (roomInput.value = randomRoom()));

    // UI language follows the chosen language; default from the browser.
    langSel.value = uiLang;
    applyI18n();
    langSel.addEventListener('change', () => {
      if (SUPPORTED.includes(langSel.value)) {
        uiLang = langSel.value;
        applyI18n();
      }
    });

    function updateVisHint() {
      visHint.textContent = visibilityPublic ? '' : t('privateHint');
    }
    visGroup.addEventListener('click', (e) => {
      const btn = e.target.closest('.seg-btn');
      if (!btn) return;
      visibilityPublic = btn.dataset.vis === 'public';
      visGroup.querySelectorAll('.seg-btn').forEach((b) => b.classList.toggle('active', b === btn));
      updateVisHint();
    });

    function flashStatus(msg, isError = false) {
      homeStatus.textContent = msg;
      homeStatus.classList.toggle('error', isError);
    }

    enterBtn.addEventListener('click', () => {
      const room = roomInput.value.trim().toLowerCase();
      if (!room) return flashStatus(t('enterRoom'), true);
      joinRoom(room, visibilityPublic);
    });

    function joinRoom(room, isPublic) {
      session = { room, lang: langSel.value, name: nameInput.value.trim(), isPublic: !!isPublic };
      startSession();
    }

    // ---- Lobby polling ----
    async function fetchRooms() {
      try {
        const res = await fetch(`${HTTP_BASE}/rooms`, { cache: 'no-store' });
        const data = await res.json();
        renderRooms(data.rooms || []);
      } catch {
        /* keep last render on transient errors */
      }
    }

    function renderRooms(rooms) {
      roomsList.innerHTML = '';
      if (!rooms.length) {
        const empty = document.createElement('div');
        empty.className = 'lobby-empty';
        empty.textContent = t('noPublicRooms');
        roomsList.appendChild(empty);
        return;
      }
      for (const r of rooms) {
        const item = document.createElement('button');
        item.className = 'room-item';
        item.type = 'button';

        const main = document.createElement('div');
        main.className = 'room-item-main';
        const code = document.createElement('span');
        code.className = 'room-item-code';
        code.textContent = r.room;
        const count = document.createElement('span');
        count.className = 'room-item-count';
        count.textContent = `👤 ${r.count}`;
        main.append(code, count);

        const members = document.createElement('div');
        members.className = 'room-item-members';
        for (const m of r.participants) {
          const chip = document.createElement('span');
          chip.className = 'chip';
          chip.textContent = `${FLAG[m.lang] || ''} ${m.name}`.trim();
          members.appendChild(chip);
        }

        item.append(main, members);
        item.addEventListener('click', () => joinRoom(r.room, true));
        roomsList.appendChild(item);
      }
    }

    function startLobby() {
      fetchRooms();
      if (!lobbyTimer) lobbyTimer = setInterval(fetchRooms, 3000);
    }
    function stopLobby() {
      if (lobbyTimer) {
        clearInterval(lobbyTimer);
        lobbyTimer = null;
      }
    }
    $('refresh').addEventListener('click', fetchRooms);

    // ====================================================================
    // Session lifecycle
    // ====================================================================
    async function startSession() {
      enterBtn.disabled = true;
      flashStatus(t('connecting'));

      try {
        stream = await navigator.mediaDevices.getUserMedia({
          audio: {
            channelCount: 1,
            sampleRate: 16000,
            echoCancellation: true,
            noiseSuppression: true,
            autoGainControl: true,
          },
        });
      } catch {
        enterBtn.disabled = false;
        return flashStatus(t('micDenied'), true);
      }

      manualClose = false;
      stopLobby();
      openSocket();
      showSession();
      enterBtn.disabled = false;
    }

    function openSocket() {
      const params = new URLSearchParams({
        room: session.room,
        lang: session.lang,
        id: myId,
        public: String(session.isPublic),
      });
      if (session.name) params.set('name', session.name);
      ws = new WebSocket(`${WS_BASE}/ws?${params}`);

      ws.onopen = () => {
        connDot.classList.add('connected');
        flashStatus('');
      };
      ws.onmessage = (e) => {
        try {
          handleMessage(JSON.parse(e.data));
        } catch {
          /* ignore malformed frames */
        }
      };
      ws.onclose = (e) => {
        connDot.classList.remove('connected');
        if (!manualClose && e.code !== 1000) scheduleReconnect();
      };
      ws.onerror = () => connDot.classList.remove('connected');
    }

    function scheduleReconnect() {
      if (reconnectTimer) return;
      appendMessage({ kind: 'error', text: t('connectionLost') });
      reconnectTimer = setTimeout(() => {
        reconnectTimer = null;
        if (!manualClose) openSocket();
      }, 2000);
    }

    function showSession() {
      homeScreen.classList.add('hidden');
      sessionScreen.classList.remove('hidden');
      roomBadge.textContent = session.room;
      visBadge.textContent = session.isPublic ? t('public') : t('private');
      myLangEl.textContent = ENDONYM[session.lang] || session.lang.toUpperCase();
      logEl.innerHTML = `<p class="log-empty">${t('waiting')}</p>`;
      interimEl = null;
      micHint.textContent = pttMode.checked ? t('holdTalk') : t('tapStart');
      loadVoices();
    }

    roomBadge.addEventListener('click', async () => {
      try {
        await navigator.clipboard.writeText(roomBadge.textContent.trim());
        const prev = visBadge.textContent;
        visBadge.textContent = t('copied');
        setTimeout(() => (visBadge.textContent = session.isPublic ? t('public') : t('private')), 1200);
        void prev;
      } catch {
        /* ignore */
      }
    });

    $('disconnect').addEventListener('click', endSession);

    function endSession() {
      manualClose = true;
      if (reconnectTimer) {
        clearTimeout(reconnectTimer);
        reconnectTimer = null;
      }
      stopRecording();
      recorder = null;
      if (stream) {
        stream.getTracks().forEach((tr) => tr.stop());
        stream = null;
      }
      if (ws) {
        ws.close(1000, 'user disconnect');
        ws = null;
      }
      if (window.speechSynthesis) speechSynthesis.cancel();
      sessionScreen.classList.add('hidden');
      homeScreen.classList.remove('hidden');
      roomInput.value = randomRoom();
      flashStatus('');
      startLobby();
    }

    // ====================================================================
    // Speaking: audio capture + start/stop control frames
    // ====================================================================
    function sendControl(type) {
      if (ws && ws.readyState === WebSocket.OPEN) ws.send(JSON.stringify({ type }));
    }

    function startRecording() {
      if (isRecording || !stream) return;
      const mime = 'audio/webm;codecs=opus';
      try {
        recorder = new MediaRecorder(stream, {
          mimeType: MediaRecorder.isTypeSupported(mime) ? mime : 'audio/webm',
          audioBitsPerSecond: 32000,
        });
      } catch {
        flashStatus(t('recNotSupported'), true);
        return;
      }
      recorder.ondataavailable = (e) => {
        if (e.data.size > 0 && ws && ws.readyState === WebSocket.OPEN) ws.send(e.data);
      };
      recorder.onstop = () => sendControl('stop'); // after the final chunk
      sendControl('start'); // open Deepgram before audio flows
      recorder.start(250);
      isRecording = true;
      micBtn.classList.add('recording');
      micHint.textContent = pttMode.checked ? t('releaseStop') : t('tapStop');
    }

    function stopRecording() {
      if (recorder && recorder.state !== 'inactive') recorder.stop();
      isRecording = false;
      micBtn.classList.remove('recording');
      micHint.textContent = pttMode.checked ? t('holdTalk') : t('tapStart');
    }

    micBtn.addEventListener('pointerdown', (e) => {
      if (pttMode.checked) {
        e.preventDefault();
        startRecording();
      }
    });
    micBtn.addEventListener('pointerup', () => {
      if (pttMode.checked) stopRecording();
    });
    micBtn.addEventListener('pointerleave', () => {
      if (pttMode.checked && isRecording) stopRecording();
    });
    micBtn.addEventListener('click', () => {
      if (!pttMode.checked) (isRecording ? stopRecording() : startRecording());
    });
    pttMode.addEventListener('change', () => {
      stopRecording();
      micHint.textContent = pttMode.checked ? t('holdTalk') : t('tapStart');
    });

    // ====================================================================
    // Incoming messages
    // ====================================================================
    function handleMessage(data) {
      const empty = logEl.querySelector('.log-empty');
      if (empty) empty.remove();
      const isOwn = data.from_id === myId;

      switch (data.type) {
        case 'interim':
          if (!interimEl) {
            interimEl = document.createElement('div');
            interimEl.className = 'msg msg-interim';
            logEl.appendChild(interimEl);
          }
          interimEl.textContent = data.text;
          scrollLog();
          break;

        case 'transcript':
          if (isOwn) {
            if (interimEl) {
              interimEl.remove();
              interimEl = null;
            }
            appendMessage({ kind: 'own', name: t('you'), text: data.text });
          } else {
            appendMessage({ kind: 'incoming', name: data.from, text: data.text });
            if (autoTtsEl.checked) speak(data.text, data.lang);
          }
          break;

        case 'translation':
          appendMessage({ kind: 'translated', name: data.from, text: data.translated });
          if (autoTtsEl.checked) speak(data.translated, data.target_lang);
          break;

        case 'error':
          appendMessage({ kind: 'error', text: data.message });
          break;
      }
    }

    function appendMessage({ kind, name, text }) {
      const div = document.createElement('div');
      div.className = `msg msg-${kind}`;
      if (name) {
        const who = document.createElement('div');
        who.className = 'msg-from';
        who.textContent = name;
        div.appendChild(who);
      }
      const body = document.createElement('div');
      body.textContent = text;
      div.appendChild(body);
      logEl.appendChild(div);
      scrollLog();
    }

    function scrollLog() {
      logEl.scrollTop = logEl.scrollHeight;
    }

    // ====================================================================
    // TTS
    // ====================================================================
    function loadVoices() {
      if (!window.speechSynthesis) return;
      const fill = () => {
        const voices = speechSynthesis.getVoices();
        voiceSelect.innerHTML = `<option value="-1">${t('voiceAuto')}</option>`;
        voices.forEach((v, i) => {
          const opt = document.createElement('option');
          opt.value = String(i);
          opt.textContent = `${v.name} (${v.lang})`;
          voiceSelect.appendChild(opt);
        });
      };
      fill();
      speechSynthesis.onvoiceschanged = fill;
    }

    function speak(text, lang) {
      if (!window.speechSynthesis) return;
      speechSynthesis.cancel();
      const utter = new SpeechSynthesisUtterance(text);
      const voices = speechSynthesis.getVoices();
      const idx = parseInt(voiceSelect.value, 10);
      if (idx >= 0 && voices[idx]) {
        utter.voice = voices[idx];
      } else if (lang) {
        const match = voices.find((v) => v.lang.toLowerCase().startsWith(lang.toLowerCase()));
        if (match) utter.voice = match;
      }
      utter.lang = lang || 'en';
      utter.rate = 1.1;
      speechSynthesis.speak(utter);
    }

    if (window.speechSynthesis) speechSynthesis.getVoices(); // prime async voice list

    // ====================================================================
    // Boot
    // ====================================================================
    startLobby();
  </script>
</Base>
