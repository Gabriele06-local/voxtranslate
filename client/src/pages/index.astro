    /* Google avatar in a video cell (overrides the gradient initials block). */
    /* Camera-off avatar: a centered, proportionate circle (its parent .avatar is
       inset:0 + place-items:center). aspect-ratio keeps it square so a square
       source never stretches; it scales with the cell but stays sensibly bounded. */
    .video-grid :global(.avatar-img) {
      width: clamp(56px, 30%, 140px); aspect-ratio: 1; border-radius: 50%;
