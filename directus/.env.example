# Directus backoffice — copy to .env and fill in. NEVER commit the real .env.

# openssl rand -hex 32   (run twice, one for each)
DIRECTUS_KEY=
DIRECTUS_SECRET=

DIRECTUS_ADMIN_EMAIL=you@example.com
DIRECTUS_ADMIN_PASSWORD=

# Supabase IPv4 Session pooler URL (the same string the app uses as DATABASE_URL),
# e.g. postgres://postgres.<ref>:<pw>@aws-0-eu-west-1.pooler.supabase.com:5432/postgres
DATABASE_URL=

DIRECTUS_PUBLIC_URL=http://localhost:8055

# The VoxTranslate server base URL the admin Flows call.
VOX_API_URL=https://voxtranslate-server-production.up.railway.app
# Shared secret — set the SAME value as ADMIN_API_SECRET on voxtranslate-server.
ADMIN_API_SECRET=
