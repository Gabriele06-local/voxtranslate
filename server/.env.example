# --- Core (required) ---
DEEPGRAM_API_KEY=your_deepgram_key_here
GROQ_API_KEY=gsk_your_groq_key_here
PORT=3001
# Comma-separated; empty = permissive (dev). Lock down in production.
ALLOWED_ORIGINS=

# --- Auth + Billing (OPTIONAL) ---
# Leave DATABASE_URL / GOOGLE_CLIENT_ID / JWT_SECRET empty to run in guest-only
# mode (no accounts, no metering). Fill all three to enable accounts + credits.

# Database
DATABASE_URL=

# Auth
GOOGLE_CLIENT_ID=
JWT_SECRET=
JWT_EXPIRY_HOURS=168

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Set these to your production frontend URL in Railway (e.g. https://voxtranslate.app).
STRIPE_SUCCESS_URL=http://localhost:4321/?checkout=success
STRIPE_CANCEL_URL=http://localhost:4321/?checkout=cancel

# Pricing (USD). user_rate = COST_PER_MINUTE * (1 + MARKUP_PERCENTAGE).
COST_PER_MINUTE=0.008
MARKUP_PERCENTAGE=0.25
FREE_CREDITS=2.00
LOW_BALANCE_THRESHOLD=0.50
MIN_BALANCE_TO_JOIN=0.05
USAGE_UPDATE_INTERVAL=5
# Optional cap on guest session length (minutes); empty = unlimited.
GUEST_MAX_MINUTES=

# Credit packages — JSON array. stripe_price_id is never sent to the client.
# IMPORTANT: wrap the value in SINGLE quotes — the JSON contains double quotes
# and dotenv would otherwise mangle them (resulting in zero packages).
CREDIT_PACKAGES='[{"id":"starter","name":"Starter","price_usd":5.00,"credits_usd":5.00,"stripe_price_id":"price_xxx1"},{"id":"plus","name":"Plus","price_usd":15.00,"credits_usd":17.00,"stripe_price_id":"price_xxx2"},{"id":"pro","name":"Pro","price_usd":30.00,"credits_usd":36.00,"stripe_price_id":"price_xxx3"},{"id":"business","name":"Business","price_usd":60.00,"credits_usd":80.00,"stripe_price_id":"price_xxx4"}]'

# --- Advanced features (OPTIONAL; sensible defaults) ---

# Room glossary
GLOSSARY_MAX_ENTRIES=200

# AI models. Offline analysis (report/sentiment/email draft) uses the report
# model; the fallback model handles primary-model errors + live suggestions.
GROQ_REPORT_MODEL=llama-3.3-70b-versatile
GROQ_FALLBACK_MODEL=llama-3.1-8b-instant

# AI feature prices (USD, user-facing).
CREDITS_REPORT_BASE=0.05
CREDITS_REPORT_PER_MINUTE=0.002
CREDITS_SENTIMENT_BASE=0.05
CREDITS_SENTIMENT_PER_PARTICIPANT=0.01
CREDITS_SENTIMENT_PER_MINUTE=0.002
CREDITS_EMAIL_DRAFT=0.02
CREDITS_SUGGESTIONS_PER_MINUTE=0.005
SUGGESTIONS_INTERVAL_SECONDS=15

# Auto language detection: how much audio to buffer for the REST probe.
AUTO_DETECT_BUFFER_MS=3000

# Resend (follow-up email). Leave empty to disable the email feature (503).
RESEND_API_KEY=
RESEND_FROM_EMAIL=
RESEND_FROM_NAME=

# Chat file upload (spec 0018). Both URL + service key must be set to enable the
# attach button; otherwise the upload endpoint returns 503. Create a PUBLIC
# Supabase Storage bucket named `chat-files` (or override SUPABASE_BUCKET).
# SUPABASE_SERVICE_KEY is the service-role key — server only, never shipped to
# the client.
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_BUCKET=chat-files
# Max upload size in bytes (default 25 MiB).
SUPABASE_MAX_UPLOAD_BYTES=26214400
